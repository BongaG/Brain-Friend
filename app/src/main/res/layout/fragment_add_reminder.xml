<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F6FF"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🧠 New Voice Reminder"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#3B2F6E"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap the mic and say your reminder out loud"
            android:textSize="14sp"
            android:textColor="#6B63A0"
            android:layout_marginBottom="28dp"/>

        <Button
            android:id="@+id/btn_mic"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:text="🎙"
            android:textSize="40sp"
            android:backgroundTint="#7B68EE"
            android:layout_marginBottom="20dp"/>


        <TextView
            android:id="@+id/tv_transcribed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:textSize="16sp"
            android:textColor="#2D2152"
            android:hint="Your reminder will appear here…"
            android:textColorHint="#B0AACC"
            android:visibility="gone"
            android:layout_marginBottom="20dp"/>


        <Button
            android:id="@+id/btn_pick_time"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="⏰  Pick reminder time"
            android:textSize="16sp"
            android:backgroundTint="#EDE9FF"
            android:textColor="#3B2F6E"
            android:layout_marginBottom="12dp"/>


        <TextView
            android:id="@+id/tv_scheduled_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textColor="#5A4BAD"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="24dp"/>


        <Button
            android:id="@+id/btn_save_reminder"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Save Reminder ✅"
            android:textSize="17sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#5B4FCF"/>

    </LinearLayout>
</ScrollView>
