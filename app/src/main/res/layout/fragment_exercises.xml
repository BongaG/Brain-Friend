<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#F8F6FF">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🧠 Brain Exercises"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#3B2F6E"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Train your brain with fun games"
        android:textSize="14sp"
        android:textColor="#6B63A0"
        android:layout_marginBottom="32dp" />

    <androidx.cardview.widget.CardView
        android:id="@+id/card_word_game"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#FFFFFF"
        android:foreground="?android:attr/selectableItemBackground">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="20dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📝 Word Scramble Game"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#3B2F6E" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Play ➡️"
                android:textSize="14sp"
                android:textColor="#5B4FCF" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>