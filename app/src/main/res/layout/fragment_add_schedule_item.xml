<?xml version="1.0" encoding="utf-8"?>


<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F6FF"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🗓️ Add to Schedule"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#3B2F6E"
            android:layout_marginBottom="20dp"/>


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="What's the event?"
            android:textSize="14sp"
            android:textColor="#7B6FB5"
            android:layout_marginBottom="6dp"/>
        <EditText
            android:id="@+id/et_schedule_title"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:hint="e.g. Math Homework"
            android:textColorHint="#C0BADC"
            android:textColor="#2D2152"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pick an emoji icon"
            android:textSize="14sp"
            android:textColor="#7B6FB5"
            android:layout_marginBottom="6dp"/>
        <EditText
            android:id="@+id/et_schedule_emoji"
            android:layout_width="80dp"
            android:layout_height="52dp"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:hint="📚"
            android:textSize="22sp"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>


        <Button
            android:id="@+id/btn_pick_time"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="⏰ Pick time"
            android:textSize="15sp"
            android:backgroundTint="#EDE9FF"
            android:textColor="#3B2F6E"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_selected_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textColor="#5A4BAD"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Duration (minutes)"
            android:textSize="14sp"
            android:textColor="#7B6FB5"
            android:layout_marginBottom="6dp"/>
        <EditText
            android:id="@+id/et_schedule_duration"
            android:layout_width="120dp"
            android:layout_height="52dp"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:hint="30"
            android:inputType="number"
            android:textColor="#2D2152"
            android:layout_marginBottom="16dp"/>


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Which day?"
            android:textSize="14sp"
            android:textColor="#7B6FB5"
            android:layout_marginBottom="6dp"/>
        <Spinner
            android:id="@+id/spinner_day"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="#FFFFFF"
            android:layout_marginBottom="16dp"/>


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Card colour"
            android:textSize="14sp"
            android:textColor="#7B6FB5"
            android:layout_marginBottom="6dp"/>
        <Spinner
            android:id="@+id/spinner_color"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="#FFFFFF"
            android:layout_marginBottom="24dp"/>


        <Button
            android:id="@+id/btn_save_schedule"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Save to Schedule ✅"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#5B4FCF"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btn_back_schedule"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="← Back"
            android:textSize="15sp"
            android:backgroundTint="#EDE9FF"
            android:textColor="#3B2F6E"/>

    </LinearLayout>
</ScrollView>
