<?xml version="1.0" encoding="utf-8"?>
<!-- item_schedule.xml  →  res/layout/ -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_schedule"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#EEEDFE">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Colour strip on left -->
        <View
            android:id="@+id/view_color_strip"
            android:layout_width="6dp"
            android:layout_height="match_parent"
            android:minHeight="72dp"
            android:background="#7F77DD"/>

        <!-- Emoji -->
        <TextView
            android:id="@+id/tv_schedule_emoji"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:textSize="26sp"
            android:gravity="center"
            android:padding="8dp"/>

        <!-- Title + time -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <TextView
                android:id="@+id/tv_schedule_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#2D2152"
                android:layout_marginBottom="4dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_schedule_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="#7B6FB5"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/tv_schedule_duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="#A09AC0"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Done badge -->
        <TextView
            android:id="@+id/tv_schedule_done"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✅"
            android:textSize="22sp"
            android:paddingEnd="12dp"
            android:visibility="gone"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>
